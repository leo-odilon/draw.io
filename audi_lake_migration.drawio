        <mxCell id="nWNinx9GMLmJqjKlsHqI-1" parent="U01bOSqINZ_HKZLMmUMp-48" style="html=1;verticalLabelPosition=bottom;align=center;labelBackgroundColor=#ffffff;verticalAlign=top;strokeWidth=2;strokeColor=#0080F0;shadow=0;dashed=0;shape=mxgraph.ios7.icons.documents;" value="Parquet &lt;br&gt;File" vertex="1">
