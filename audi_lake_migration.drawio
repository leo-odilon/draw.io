        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-1" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=25;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" value="1" vertex="1">
          <mxGeometry height="40" width="40" x="70" y="118" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-6" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=13;" value="&lt;b&gt;Salesforce (Origem do evento)&lt;/b&gt;&lt;br&gt;A &lt;strong data-start=&quot;178&quot; data-end=&quot;219&quot;&gt;&lt;span class=&quot;hover:entity-accent entity-underline inline cursor-pointer align-baseline&quot;&gt;&lt;span class=&quot;whitespace-normal&quot;&gt;Salesforce&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt; dispara um &lt;strong data-start=&quot;231&quot; data-end=&quot;262&quot;&gt;Outbound Message (SOAP/XML)&lt;/strong&gt; quando ocorre um evento de negócio (ex.: criação de pedido), enviando os dados do evento de forma assíncrona para o sistema de integração." vertex="1">
          <mxGeometry height="50" width="730" x="140" y="700" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-7" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=25;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" value="1" vertex="1">
          <mxGeometry height="40" width="40" x="80" y="710" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-8" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=25;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" value="2" vertex="1">
          <mxGeometry height="40" width="40" x="80" y="800" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-9" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=13;" value="&lt;strong data-start=&quot;144&quot; data-end=&quot;201&quot;&gt;Camada de entrada na AWS (Segurança e Roteamento)&lt;/strong&gt;&lt;br&gt;O evento é recebido na &lt;strong data-start=&quot;227&quot; data-end=&quot;268&quot;&gt;&lt;span class=&quot;hover:entity-accent entity-underline inline cursor-pointer align-baseline&quot;&gt;&lt;span class=&quot;whitespace-normal&quot;&gt;Amazon Web Services&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt; por um &lt;strong data-start=&quot;276&quot; data-end=&quot;283&quot;&gt;WAF&lt;/strong&gt;, que aplica regras de segurança e controle de acesso, integrado a um &lt;strong data-start=&quot;353&quot; data-end=&quot;368&quot;&gt;API Gateway&lt;/strong&gt; responsável por expor &lt;strong data-start=&quot;391&quot; data-end=&quot;410&quot;&gt;rotas dedicadas&lt;/strong&gt; para cada tipo de Outbound Message." vertex="1">
          <mxGeometry height="80" width="740" x="140" y="787" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-10" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=25;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" value="3" vertex="1">
          <mxGeometry height="40" width="40" x="80" y="880" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-11" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=13;" value="&lt;strong data-start=&quot;580&quot; data-end=&quot;616&quot;&gt;Processamento e Orquestração&lt;/strong&gt;&lt;br&gt;O &lt;strong data-start=&quot;621&quot; data-end=&quot;636&quot;&gt;API Gateway&lt;/strong&gt; encaminha a requisição para uma &lt;strong data-start=&quot;669&quot; data-end=&quot;686&quot;&gt;função Lambda&lt;/strong&gt;, que interpreta o XML (SOAP), transforma o payload em JSON e aciona o &lt;strong data-start=&quot;757&quot; data-end=&quot;771&quot;&gt;Databricks&lt;/strong&gt; para iniciar o job de processamento." vertex="1">
          <mxGeometry height="80" width="730" x="140" y="870" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-13" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=13;" value="&lt;strong data-start=&quot;83&quot; data-end=&quot;130&quot;&gt;Camada de segurança na saída para o SAP&lt;/strong&gt;&lt;br&gt;As requisições geradas pelo &lt;strong data-start=&quot;161&quot; data-end=&quot;202&quot;&gt;&lt;span class=&quot;hover:entity-accent entity-underline inline cursor-pointer align-baseline&quot;&gt;&lt;span class=&quot;whitespace-normal&quot;&gt;Databricks&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt; passam por um &lt;strong data-start=&quot;217&quot; data-end=&quot;224&quot;&gt;WAF&lt;/strong&gt;, responsável por aplicar controles de segurança e proteção antes do envio para o &lt;strong data-start=&quot;306&quot; data-end=&quot;347&quot;&gt;&lt;span class=&quot;hover:entity-accent entity-underline inline cursor-pointer align-baseline&quot;&gt;&lt;span class=&quot;whitespace-normal&quot;&gt;SAP&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt;." vertex="1">
          <mxGeometry height="60" width="740" x="1000" y="700" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-14" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=25;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" value="4" vertex="1">
          <mxGeometry height="40" width="40" x="940" y="710" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-15" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;strong data-start=&quot;70&quot; data-end=&quot;104&quot;&gt;Integração com SAP via RFC&lt;/strong&gt;&lt;br&gt;A partir do &lt;strong data-start=&quot;119&quot; data-end=&quot;126&quot;&gt;WAF&lt;/strong&gt;, um &lt;strong data-start=&quot;131&quot; data-end=&quot;146&quot;&gt;ALB interno&lt;/strong&gt; recebe a requisição e a encaminha para uma &lt;strong data-start=&quot;190&quot; data-end=&quot;225&quot;&gt;instância EC2 em subnet privada&lt;/strong&gt;, responsável por executar o &lt;strong data-start=&quot;254&quot; data-end=&quot;279&quot; data-is-only-node=&quot;&quot;&gt;SAP NetWeaver RFC SDK&lt;/strong&gt; e estabelecer a comunicação com o SAP via &lt;strong data-start=&quot;322&quot; data-end=&quot;329&quot;&gt;RFC&lt;/strong&gt;." vertex="1">
          <mxGeometry height="60" width="730" x="1000" y="780" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-16" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=25;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" value="5" vertex="1">
          <mxGeometry height="40" width="40" x="940" y="790" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-18" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;strong data-start=&quot;81&quot; data-end=&quot;128&quot;&gt;Conectividade com o ambiente on-premise&lt;/strong&gt;&lt;br&gt;A comunicação da &lt;strong data-start=&quot;148&quot; data-end=&quot;166&quot;&gt;subnet privada&lt;/strong&gt; com o ambiente &lt;strong data-start=&quot;182&quot; data-end=&quot;196&quot;&gt;on-premise&lt;/strong&gt; é realizada por meio do &lt;strong data-start=&quot;221&quot; data-end=&quot;262&quot;&gt;&lt;span class=&quot;hover:entity-accent entity-underline inline cursor-pointer align-baseline&quot;&gt;&lt;span class=&quot;whitespace-normal&quot;&gt;AWS Transit Gateway&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt; integrado ao &lt;strong data-start=&quot;276&quot; data-end=&quot;317&quot;&gt;&lt;span class=&quot;hover:entity-accent entity-underline inline cursor-pointer align-baseline&quot;&gt;&lt;span class=&quot;whitespace-normal&quot;&gt;AWS Direct Connect (Conexão já existente).&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt;" vertex="1">
          <mxGeometry height="60" width="760" x="1000" y="860" as="geometry" />
        </mxCell>
        <mxCell id="eSCB0hy_WZhfAJG-kMdt-19" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=25;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" value="6" vertex="1">
          <mxGeometry height="40" width="40" x="940" y="870" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
